  "keyFeatures": [
    "One-line photo editing workflow with quick_edit()",
    "Async/await support with concurrent uploads and downloads",
    "AI-powered batch editing using trained profiles",
    "Support for RAW and JPEG formats",
    "Progress tracking callbacks for long operations",
    "XMP file generation compatible with Lightroom/Photoshop",
    "Optional JPEG export for client delivery",
    "MD5 hash verification for upload integrity"
